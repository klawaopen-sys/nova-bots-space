# Bot Token from BotFather
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Numeric IDs of Telegram administrators (separated by commas)
ADMIN_IDS=1520955083,1281474248

# Default bot language (uk, ru, en)
DEFAULT_LANG=uk

# Google Sheets Config
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEETS_ID=YOUR_GOOGLE_SHEETS_ID

# Salon and Home addresses for booking shifts
ADDRESS_SALON=📍 м. Ніжин, вул. Шевченка 128 (Салон)
ADDRESS_HOME=🏠 м. Ніжин, вул. Сонячна 15 (Дім)

# Work schedule: Shift start date (YYYY-MM-DD) for 2/2 cycle
SHIFT_START_DATE=2026-04-21

# Configurable work time slots (separated by commas)
WORK_HOURS=10:00,12:00,14:00,16:00
